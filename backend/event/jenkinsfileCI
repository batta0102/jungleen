pipeline {
    agent any
    tools {
        jdk 'JDK21'  // Assure-toi que 'JDK21' est configuré dans Jenkins
        maven 'Maven3'  // Assure-toi que 'Maven3' est configuré dans Jenkins
    }
    environment {
        SONARQUBE_URL = 'http://localhost:9000'  // URL de ton serveur SonarQube
        SONARQUBE_CREDENTIALS = credentials('sonar-token')  // Utilise les credentials SonarQube dans Jenkins
    }
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/batta0102/jungleen.git'  // Cloner ton repo GitHub
            }
        }
        stage('Maven Build') {
            steps {
                sh './mvnw clean install -DskipTests'  // Compiler ton projet sans exécuter les tests
            }
        }
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarQube Server') {  
                    dir('backend/event') {  // Change le répertoire pour ton microservice Event
                        sh '''
                        mvn sonar:sonar 
                            -Dsonar.projectKey=event  // Clé du projet SonarQube
                            -Dsonar.projectName=event  // Nom du projet dans SonarQube
                            -Dsonar.sources=src  // Le répertoire où se trouve ton code source
                            -DskipTests  // Pour ignorer les tests pendant l'analyse
                        '''
                    }
                }
            }
        }
    }
    post {
        success {
            echo 'Pipeline exécuté avec succès et analyse SonarQube réussie !'
        }
        failure {
            echo 'Une erreur s\'est produite pendant l\'exécution du pipeline ou l\'analyse SonarQube.'
        }
        always {
            cleanWs()  // Nettoie l'espace de travail à la fin du pipeline
        }
    }
}
