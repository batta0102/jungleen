pipeline {
    agent any
    tools {
        jdk 'JDK21'  // Assure-toi que 'JDK21' est configuré dans Jenkins
        maven 'Maven3'  // Assure-toi que 'Maven3' est configuré dans Jenkins
    }
    stages {
        stage('Check Java') {
            steps {
                sh 'java -version'
            }
        }
        stage('Check Maven') {
            steps {
                sh 'mvn -version'
            }
        }
        stage('Check Git') {
            steps {
                sh 'git --version'
            }
        }
        stage('Check Docker') {
            steps {
                sh 'docker --version || echo "Docker not available"'
            }
        }
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/batta0102/jungleen.git'
            }
        }
        stage('List Files') {
            steps {
                sh 'ls -la'
            }
        }
        stage('Maven Build') {
            steps {
                dir('backend/event') {  // Assure-toi que tu es dans le bon répertoire
                    sh 'mvn clean install -DskipTests'  // Exécute Maven dans le répertoire backend/event
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarQube Server') {
                    dir('backend/event') {  // Utilise le même répertoire pour l'analyse
                        sh '''
                        mvn sonar:sonar 
                            -Dsonar.projectKey=event  // Clé du projet SonarQube
                            -Dsonar.projectName=event  // Nom du projet dans SonarQube
                            -Dsonar.sources=src  // Le répertoire où se trouve ton code source
                            -DskipTests  // Pour ignorer les tests pendant l'analyse
                        '''
                    }
                }
            }
        }
    }
    post {
        success {
            echo 'Pipeline exécuté avec succès et analyse SonarQube réussie !'
        }
        failure {
            echo 'Une erreur s\'est produite pendant l\'exécution du pipeline ou l\'analyse SonarQube.'
        }
        always {
            cleanWs()  // Nettoie l'espace de travail à la fin du pipeline
        }
    }
}
