pipeline {
    agent any
    tools {
        jdk 'JDK21'
        maven 'Maven3'
    }
    stages {
        stage('Check Java') {
            steps {
                sh 'java -version'
            }
        }
        stage('Check Maven') {
            steps {
                sh 'mvn -version'
            }
        }
        stage('Check Git') {
            steps {
                sh 'git --version'
            }
        }
        stage('Check Docker') {
            steps {
                sh 'docker --version || echo "Docker not available"'
            }
        }
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/batta0102/jungleen.git'
            }
        }
        stage('List Files') {
            steps {
                sh 'ls -la'
            }
        }
        stage('Maven Build') {
            steps {
                dir('backend/event') {
                    sh 'mvn clean install -DskipTests'
                }
            }
        }
        stage('Maven Test') {
            steps {
                dir('backend/event') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'backend/event/target/surefire-reports/*.xml'
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarQube Server') {
                    dir('backend/event') {
                        sh '''
                            mvn sonar:sonar \
                                -Dsonar.projectKey=event \
                                -Dsonar.projectName=event \
                                -Dsonar.sources=src/main/java \
                                -Dsonar.tests=src/test/java \
                                -Dsonar.java.binaries=target/classes \
                                -Dsonar.host.url=http://host.docker.internal:9000
                        '''
                    }
                }
            }
        }
    }
    post {
        success {
            echo 'Pipeline exécuté avec succès !'
        }
        failure {
            echo 'Une erreur est survenue pendant le pipeline.'
        }
        always {
            cleanWs()
        }
    }
}
