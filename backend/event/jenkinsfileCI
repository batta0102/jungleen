pipeline {
    agent any
    tools {
        jdk 'JDK21'
        maven 'Maven3'
    }

    environment {
        DOCKER_IMAGE_BACKEND = 'bayakhouini/event-backend'
        DOCKER_TAG = "${BUILD_NUMBER}"
    }

    stages {
        stage('Check Java') {
            steps { sh 'java -version' }
        }
        stage('Check Maven') {
            steps { sh 'mvn -version' }
        }
        stage('Check Git') {
            steps { sh 'git --version' }
        }
        stage('Check Docker') {
            steps { sh 'docker --version' }
        }
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/batta0102/jungleen.git'
            }
        }
        stage('Maven Build') {
            steps {
                dir('backend/event') {
                    sh 'mvn clean install -DskipTests'
                }
            }
        }
        stage('Maven Test') {
            steps {
                dir('backend/event') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'backend/event/target/surefire-reports/*.xml'
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarQube Server') {
                    dir('backend/event') {
                        sh '''
                            mvn sonar:sonar \
                                -Dsonar.projectKey=event \
                                -Dsonar.projectName=event \
                                -Dsonar.sources=src/main/java \
                                -Dsonar.tests=src/test/java \
                                -Dsonar.java.binaries=target/classes \
                                -Dsonar.host.url=http://172.17.0.1:9000
                        '''
                    }
                }
            }
        }
        stage('Deploy to Nexus') {
            steps {
                dir('backend/event') {
                    sh '''
                        mvn deploy \
                            -DskipTests \
                            -DaltDeploymentRepository=nexus::default::http://172.17.0.1:8081/repository/maven-snapshots/
                    '''
                }
            }
        }
        stage('Build Docker Image') {
            steps {
                sh "docker build -t ${DOCKER_IMAGE_BACKEND}:${DOCKER_TAG} ./backend/event"
                sh "docker tag ${DOCKER_IMAGE_BACKEND}:${DOCKER_TAG} ${DOCKER_IMAGE_BACKEND}:latest"
            }
        }
        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                    sh "docker push ${DOCKER_IMAGE_BACKEND}:${DOCKER_TAG}"
                    sh "docker push ${DOCKER_IMAGE_BACKEND}:latest"
                }
            }
        }
    }
    post {
        success {
            echo 'Pipeline executed successfully!'
        }
        failure {
            echo 'An error occurred during the pipeline.'
        }
        always {
            cleanWs()
            sh 'docker logout || true'
        }
    }
}
