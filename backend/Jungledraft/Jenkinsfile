pipeline {
    agent any

    tools {
        jdk 'JDK17'
    }

    environment {
        IMAGE_NAME = "nouhasd/jungledraft:latest"
    }

    stages {

        stage('Build JAR') {
            steps {
                dir('backend/Jungledraft') {
                    sh '/usr/bin/mvn clean package -DskipTests'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    dir('backend/Jungledraft') {
                        sh '/usr/bin/mvn sonar:sonar -Dsonar.projectKey=jungledraft'
                    }
                }
            }
        }

        stage('Deploy to Nexus') {
            steps {
                configFileProvider([
                    configFile(
                        fileId: '7441f397-a3e6-4940-893e-6a097a26370e',
                        variable: 'MAVEN_SETTINGS'
                    )
                ]) {
                    dir('backend/Jungledraft') {
                        sh '/usr/bin/mvn deploy -s $MAVEN_SETTINGS -DskipTests'
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('backend/Jungledraft') {
                    sh 'docker build -t $IMAGE_NAME .'
                }
            }
        }

        stage('Push to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {
                    sh 'echo $PASS | docker login -u $USER --password-stdin'
                    sh 'docker push $IMAGE_NAME'
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                dir('backend/Jungledraft') {
                    sh 'kubectl apply -f k8s-backend.yaml'
                    sh 'kubectl rollout restart deployment jungledraft-backend'
                }
            }
        }
    }
}
