pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                dir('backend/Jungledraft') {
                    sh '/usr/bin/mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                dir('backend/Jungledraft') {
                    sh '/usr/bin/mvn test'
                }
            }
        }

        stage('Package') {
            steps {
                dir('backend/Jungledraft') {
                    sh '/usr/bin/mvn package'
                }
            }
        }
    }
}
