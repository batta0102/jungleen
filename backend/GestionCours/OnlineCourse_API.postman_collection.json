{
  "info": {
    "name": "OnlineCourse API",
    "description": "REST API for managing online courses with full CRUD operations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Course",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201 Created', function() {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Response has success flag', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.eql(true);",
              "});",
              "pm.test('Response contains course id', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.id).to.exist;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Spring Boot Fundamentals\",\n  \"level\": \"BEGINNER\",\n  \"tutorId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/add",
          "host": ["{{baseUrl}}"],
          "path": ["add"]
        },
        "description": "Create a new online course"
      },
      "response": []
    },
    {
      "name": "Get All Courses",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200 OK', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has success flag', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.eql(true);",
              "});",
              "pm.test('Data is an array', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}",
          "host": ["{{baseUrl}}"]
        },
        "description": "Retrieve all online courses"
      },
      "response": []
    },
    {
      "name": "Get Course by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200 OK', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has course data', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.id).to.exist;",
              "    pm.expect(jsonData.data.title).to.exist;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/1",
          "host": ["{{baseUrl}}"],
          "path": ["1"]
        },
        "description": "Retrieve a specific course by ID"
      },
      "response": []
    },
    {
      "name": "Update Course",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200 OK', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Course updated successfully', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.include('updated');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
