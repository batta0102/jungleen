              "pm.test('Status is 200 OK', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Course deleted successfully', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.include('deleted');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
