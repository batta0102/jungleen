  "item": [
    {
      "name": "Create Session",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201 Created', function() {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Response has success flag', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.eql(true);",
              "});",
              "pm.test('Response contains session id', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.id).to.exist;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"date\": \"2026-03-20T10:00:00\",\n  \"capacity\": 30,\n  \"meetingLink\": \"https://meet.google.com/abc-def-ghi\",\n  \"courseId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/add",
          "host": ["{{baseUrl}}"],
          "path": ["add"]
        },
        "description": "Create a new online session"
      },
